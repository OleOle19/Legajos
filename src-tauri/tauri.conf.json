{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Legajo RH",
  "version": "0.1.0",
  "identifier": "pe.legajorh.desktop",
  "build": {
    "beforeBuildCommand": "npm.cmd run build:ui",
    "beforeDevCommand": "npm.cmd run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Legajo RH",
        "width": 1500,
        "height": 980,
        "minWidth": 1080,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
